#!/bin/sh
#
# S98lddmodules - Load/unload LDD3 kernel modules at startup/shutdown
# Handles: scull, faulty (misc-modules), and hello (misc-modules)
#

SCULL_MODULE="scull"
FAULTY_MODULE="faulty"
HELLO_MODULE="hello"
mode="664"

# Kernel modules are installed by buildroot under /lib/modules/$(uname -r)/extra/
# or a similar path depending on INSTALL_MOD_PATH usage.
# modprobe uses /lib/modules; insmod needs explicit path.
MODULES_DIR="/lib/modules/$(uname -r)/extra"

# ---- scull helpers ----------------------------------------------------------

scull_load() {
    echo "Loading scull module..."
    insmod ${MODULES_DIR}/scull.ko $* || exit 1

    # Retrieve major number assigned to scull
    local major
    major=$(awk "\$2==\"${SCULL_MODULE}\" {print \$1}" /proc/devices)

    if [ -z "${major}" ]; then
        echo "ERROR: scull major number not found in /proc/devices" >&2
        return 1
    fi

    # Remove stale device nodes and recreate
    rm -f /dev/scull[0-3]
    mknod /dev/scull0 c ${major} 0
    mknod /dev/scull1 c ${major} 1
    mknod /dev/scull2 c ${major} 2
    mknod /dev/scull3 c ${major} 3
    ln -sf scull0 /dev/scull

    chmod 664 /dev/scull[0-3]

    rm -f /dev/scullpipe[0-3]
    mknod /dev/scullpipe0 c ${major} 4
    mknod /dev/scullpipe1 c ${major} 5
    mknod /dev/scullpipe2 c ${major} 6
    mknod /dev/scullpipe3 c ${major} 7
    ln -sf scullpipe0 /dev/scullpipe
    chmod 664 /dev/scullpipe[0-3]

    rm -f /dev/scullsingle
    mknod /dev/scullsingle  c ${major} 8
    chmod 664 /dev/scullsingle

    rm -f /dev/sculluid
    mknod /dev/sculluid     c ${major} 9
    chmod 664 /dev/sculluid

    rm -f /dev/scullwuid
    mknod /dev/scullwuid    c ${major} 10
    chmod 664 /dev/scullwuid

    rm -f /dev/scullpriv
    mknod /dev/scullpriv    c ${major} 11
    chmod 664 /dev/scullpriv

    echo "scull loaded (major=${major})"
}

scull_unload() {
    echo "Unloading scull module..."
    rmmod ${SCULL_MODULE} 2>/dev/null || true
    rm -f /dev/scull /dev/scull[0-3]
    rm -f /dev/scullpipe /dev/scullpipe[0-3]
    rm -f /dev/scullsingle /dev/sculluid /dev/scullwuid /dev/scullpriv
    echo "scull unloaded"
}

# ---- faulty helpers ---------------------------------------------------------

faulty_load() {
    echo "Loading faulty module..."
    insmod ${MODULES_DIR}/faulty.ko $* || exit 1

    local major
    major=$(awk "\$2==\"${FAULTY_MODULE}\" {print \$1}" /proc/devices)

    if [ ! -z "${major}" ]; then
        rm -f /dev/faulty
        mknod /dev/faulty c ${major} 0
        chmod 664 /dev/faulty
        echo "faulty loaded (major=${major})"
    else
        echo "faulty loaded (no char device allocated)"
    fi
}

faulty_unload() {
    echo "Unloading faulty module..."
    rmmod ${FAULTY_MODULE} 2>/dev/null || true
    rm -f /dev/faulty
    echo "faulty unloaded"
}

# ---- hello helpers ----------------------------------------------------------

hello_load() {
    echo "Loading hello module..."
    modprobe hello || insmod ${MODULES_DIR}/hello.ko
    echo "hello loaded"
}

hello_unload() {
    echo "Unloading hello module..."
    rmmod ${HELLO_MODULE} 2>/dev/null || true
    echo "hello unloaded"
}

# ---- main -------------------------------------------------------------------

case "$1" in
    start)
        scull_load
        faulty_load
        hello_load
        ;;
    stop)
        hello_unload
        faulty_unload
        scull_unload
        ;;
    restart)
        $0 stop
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
